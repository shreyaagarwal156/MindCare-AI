# ── Application ─────────────────────────────────
APP_NAME=MindCare AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── ML Model ────────────────────────────────────
MODEL_PATH=../ml-original/final_mental_health_model
TOKENIZER_NAME=bert-base-uncased

# ── Ollama LLM ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── CORS ────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── JWT Auth (planned) ──────────────────────────
# JWT_SECRET_KEY=your-super-secret-key-change-me
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=60

# ── Database (planned) ─────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mindcare
